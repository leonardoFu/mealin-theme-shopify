{%- comment -%}
  Placeholder sample slot for the good-photo modal.
  Shown until a real image is set in the theme editor.
  Accepts: label (string)
{%- endcomment -%}
<div class="good-photo-modal__sample good-photo-modal__sample--placeholder">
  <svg class="good-photo-modal__sample-placeholder-icon" aria-hidden="true" focusable="false" viewBox="0 0 24 24" fill="none">
    <rect x="3" y="6" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.4"/>
    <circle cx="12" cy="13" r="3.5" stroke="currentColor" stroke-width="1.4"/>
    <path d="M8 6l1.2-2h5.6L16 6" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>
  </svg>
  <span class="visually-hidden">{{ label }}</span>
</div>
