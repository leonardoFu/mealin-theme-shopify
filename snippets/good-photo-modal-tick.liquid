{%- comment -%}
  Refined check / cross marker for the good-photo modal lists.
  Accepts: type ('good' = check, 'bad' = cross)
{%- endcomment -%}
{%- if type == 'bad' -%}
  <svg class="good-photo-modal__list-icon" aria-hidden="true" focusable="false" viewBox="0 0 16 16" fill="none">
    <path d="M3.5 3.5l9 9M12.5 3.5l-9 9" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
  </svg>
{%- else -%}
  <svg class="good-photo-modal__list-icon" aria-hidden="true" focusable="false" viewBox="0 0 16 16" fill="none">
    <path d="M2.5 8.5l3.5 4L14 3" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
{%- endif -%}
