{%- style -%}
  #shopify-section-{{ section.id }} .craft-module {
    padding: 6rem 0;
    text-align: center;
    color: rgb(var(--color-foreground));
    background-color: rgb(var(--color-background));
  }

  {%- if section.settings.background_tint -%}
    #shopify-section-{{ section.id }} .craft-module {
      background-color: rgba(var(--color-foreground), 0.03);
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .craft-heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: calc(var(--font-heading-scale) * 0.06rem);
    line-height: calc(1 + 0.3 / max(1, var(--font-heading-scale)));
  }

  #shopify-section-{{ section.id }} .craft-body {
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  .craft-wrap {
    max-width: 120rem;
    margin: 0 auto;
    padding-left: 1.6rem;
    padding-right: 1.6rem;
  }

  @media screen and (min-width: 750px) {
    .craft-wrap {
      padding-left: 4rem;
      padding-right: 4rem;
    }
  }

  .craft-materials__heading {
    font-size: calc(var(--font-heading-scale) * 2.8rem);
    margin: 0 0 2rem;
  }

  @media screen and (min-width: 750px) {
    .craft-materials__heading {
      font-size: calc(var(--font-heading-scale) * 3.6rem);
    }
  }

  .craft-materials__body {
    font-size: 1.6rem;
    max-width: 64rem;
    margin: 0 auto;
    line-height: 1.8;
    color: rgba(var(--color-foreground), 0.75);
  }

  .craft-materials__body p {
    margin: 0;
  }
{%- endstyle -%}

<div class="craft-module">
  <div class="craft-wrap">
    {%- if section.settings.heading != blank -%}
      <h2 class="craft-heading craft-materials__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <div class="craft-body craft-materials__body">
        {{ section.settings.body }}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Craft · Built to last",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "background_tint",
      "label": "Tinted background",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built to last"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>Every portrait is painted with real oil pigments on artist-grade, gallery-wrapped canvas — the same materials found in museum collections. The result is a piece with rich color depth and physical texture that stays vivid for decades, not a print that fades on a shelf. This is an heirloom, made to outlast the moment it captures.</p>"
    }
  ],
  "presets": [
    {
      "name": "Craft · Built to last"
    }
  ]
}
{% endschema %}
