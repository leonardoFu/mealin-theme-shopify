{%- style -%}
  .memorial-process {
    padding: clamp(4rem, 8vw, 7rem) 1.5rem;
    max-width: 72rem;
    margin: 0 auto;
  }

  .memorial-process__label {
    font-family: 'Playfair Display', 'Georgia', 'Times New Roman', serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #999;
    text-align: center;
    margin: 0 0 1rem;
  }

  .memorial-process__heading {
    font-family: 'Playfair Display', 'Georgia', 'Times New Roman', serif;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 400;
    text-align: center;
    color: #1a1a1a;
    margin: 0 0 3rem;
  }

  .memorial-process__layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }

  @media (min-width: 750px) {
    .memorial-process__layout {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }

  .memorial-process__media img {
    width: 100%;
    height: auto;
    border-radius: 2px;
  }

  .memorial-process__text {
    font-family: 'Playfair Display', 'Georgia', 'Times New Roman', serif;
    font-size: clamp(1rem, 2vw, 1.15rem);
    line-height: 1.85;
    color: #3a3a3a;
    font-weight: 300;
  }

  .memorial-process__text p {
    margin: 0 0 1rem;
  }

  .memorial-process__text p:last-child {
    margin-bottom: 0;
  }
{%- endstyle -%}

<section class="memorial-process" data-section-id="{{ section.id }}">
  {%- if section.settings.label != blank -%}
    <p class="memorial-process__label">{{ section.settings.label }}</p>
  {%- endif -%}
  {%- if section.settings.heading != blank -%}
    <h2 class="memorial-process__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="memorial-process__layout">
    <div class="memorial-process__media">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1200
          | image_tag:
            widths: '400, 600, 800, 1200',
            sizes: '(min-width: 750px) 50vw, 100vw',
            loading: 'lazy'
        }}
      {%- else -%}
        {{ 'image' | placeholder_svg_tag }}
      {%- endif -%}
    </div>
    <div class="memorial-process__text">
      {%- if section.settings.body_text != blank -%}
        {{ section.settings.body_text }}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Memorial Process",
  "tag": "section",
  "class": "memorial-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Painted by Hand"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real paint. Real brushstrokes. Real artists."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Process image"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>Every portrait is painted by a trained fine-art portraitist using museum-grade oils on artist-grade linen canvas. No AI generation, no digital printing, no shortcuts.</p><p>The same techniques that have preserved masterworks for centuries will keep your companion's likeness vivid for generations to come.</p>"
    }
  ],
  "presets": [
    {
      "name": "Memorial Process"
    }
  ]
}
{% endschema %}
