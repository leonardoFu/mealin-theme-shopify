{%- style -%}
  #shopify-section-{{ section.id }} .hiw-module {
    padding: 6rem 0;
    text-align: center;
    color: rgb(var(--color-foreground));
    background-color: rgb(var(--color-background));
  }

  {%- if section.settings.background_tint -%}
    #shopify-section-{{ section.id }} .hiw-module {
      background-color: rgba(var(--color-foreground), 0.03);
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .hiw-heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: calc(var(--font-heading-scale) * 0.06rem);
    line-height: calc(1 + 0.3 / max(1, var(--font-heading-scale)));
  }

  #shopify-section-{{ section.id }} .hiw-body {
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  .hiw-wrap {
    max-width: 120rem;
    margin: 0 auto;
    padding-left: 1.6rem;
    padding-right: 1.6rem;
  }

  @media screen and (min-width: 750px) {
    .hiw-wrap {
      padding-left: 4rem;
      padding-right: 4rem;
    }
  }

  .hiw-process__heading {
    font-size: calc(var(--font-heading-scale) * 2.8rem);
    margin: 0 0 1.2rem;
  }

  @media screen and (min-width: 750px) {
    .hiw-process__heading {
      font-size: calc(var(--font-heading-scale) * 3.6rem);
    }
  }

  .hiw-process__caption {
    font-size: 1.4rem;
    color: rgba(var(--color-foreground), 0.6);
    margin: 0 0 3.2rem;
    font-style: italic;
  }

  .hiw-process__video {
    max-width: 72rem;
    margin: 0 auto 3.2rem;
  }

  .hiw-process__video iframe {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
  }

  .hiw-timeline {
    max-width: 58rem;
    margin: 1.2rem auto 0;
    text-align: left;
  }

  .hiw-tstep {
    display: grid;
    grid-template-columns: 5.6rem 1fr;
    column-gap: 2rem;
    align-items: stretch;
  }

  .hiw-tstep__rail {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hiw-tstep__num {
    font-family: var(--serif, 'Playfair Display', serif);
    font-size: 2rem;
    line-height: 1;
    color: var(--maelin-gold-dark);
    padding-top: 0.2rem;
  }

  .hiw-tstep__line {
    flex: 1 1 auto;
    width: 1px;
    margin: 0.9rem 0 0;
    background: var(--maelin-gold-accent);
    opacity: 0.45;
  }

  .hiw-tstep:last-child .hiw-tstep__line {
    display: none;
  }

  .hiw-tstep__body {
    padding-bottom: 3rem;
  }

  .hiw-tstep:last-child .hiw-tstep__body {
    padding-bottom: 0;
  }

  .hiw-tstep__label {
    font-size: calc(var(--font-heading-scale) * 1.7rem);
    margin: 0 0 0.4rem;
  }

  .hiw-tstep__caption {
    font-size: 1.4rem;
    margin: 0;
    line-height: 1.55;
    color: rgba(var(--color-foreground), 0.65);
  }
{%- endstyle -%}

<div class="hiw-module">
  <div class="hiw-wrap">
    {%- if section.settings.heading != blank -%}
      <h2 class="hiw-heading hiw-process__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.caption != blank -%}
      <p class="hiw-body hiw-process__caption">{{ section.settings.caption }}</p>
    {%- endif -%}

    {%- if section.settings.video_url != blank -%}
      <div class="hiw-process__video">
        <iframe
          src="{{ section.settings.video_url }}"
          allow="autoplay; encrypted-media"
          allowfullscreen
          loading="lazy"
          title="Process video"
        ></iframe>
      </div>
    {%- endif -%}

    <div class="hiw-timeline">
      {%- for block in section.blocks -%}
        {%- assign step_num = forloop.index | prepend: '0' -%}
        <div class="hiw-tstep" {{ block.shopify_attributes }}>
          <div class="hiw-tstep__rail" aria-hidden="true">
            <span class="hiw-tstep__num">{{ step_num }}</span>
            <span class="hiw-tstep__line"></span>
          </div>
          <div class="hiw-tstep__body">
            {%- if block.settings.label != blank -%}
              <h3 class="hiw-heading hiw-tstep__label">{{ block.settings.label }}</h3>
            {%- endif -%}
            {%- if block.settings.caption != blank -%}
              <p class="hiw-body hiw-tstep__caption">{{ block.settings.caption }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "HIW · Behind the easel",
  "tag": "section",
  "class": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "checkbox",
      "id": "background_tint",
      "label": "Tinted background",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Behind the easel"
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption line",
      "default": "While you wait, here's what happens in the studio. Every portrait moves through the same patient eight-stage sequence — never rushed, never shortcut."
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video embed URL (optional)",
      "info": "Paste a YouTube or Vimeo embed URL. Leave blank to hide."
    }
  ],
  "blocks": [
    {
      "type": "stage",
      "name": "Stage",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Stage"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption",
          "default": "Describe this stage of the process."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HIW · Behind the easel",
      "blocks": [
        { "type": "stage", "settings": { "label": "Style direction", "caption": "We translate your photo and preferences into a clear painterly brief for the artist." } },
        { "type": "stage", "settings": { "label": "Stretching the canvas", "caption": "Artist-grade linen is hand-stretched and primed over a solid wooden frame." } },
        { "type": "stage", "settings": { "label": "Sketch & drawing", "caption": "Proportions and likeness are carefully mapped and locked into the underdrawing." } },
        { "type": "stage", "settings": { "label": "Blocking the tones", "caption": "Broad masses of colour establish the light, shadow and overall palette." } },
        { "type": "stage", "settings": { "label": "Building the detail", "caption": "Layer by layer, the eyes, fur and personality are brought to life." } },
        { "type": "stage", "settings": { "label": "Natural drying", "caption": "The oils are left to cure slowly in open air — the patience the work demands." } },
        { "type": "stage", "settings": { "label": "Varnish finish", "caption": "A final varnish unifies the surface and protects the colour for decades." } },
        { "type": "stage", "settings": { "label": "Hand-framing", "caption": "The cured canvas is hand-mounted into your chosen frame, ready to hang." } }
      ]
    }
  ]
}
{% endschema %}
