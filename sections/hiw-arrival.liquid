{%- style -%}
  #shopify-section-{{ section.id }} .hiw-module {
    padding: 6rem 0;
    text-align: center;
    color: rgb(var(--color-foreground));
    background-color: rgb(var(--color-background));
  }

  {%- if section.settings.background_tint -%}
    #shopify-section-{{ section.id }} .hiw-module {
      background-color: rgba(var(--color-foreground), 0.03);
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .hiw-heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: calc(var(--font-heading-scale) * 0.06rem);
    line-height: calc(1 + 0.3 / max(1, var(--font-heading-scale)));
  }

  #shopify-section-{{ section.id }} .hiw-body {
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  .hiw-wrap {
    max-width: 120rem;
    margin: 0 auto;
    padding-left: 1.6rem;
    padding-right: 1.6rem;
  }

  @media screen and (min-width: 750px) {
    .hiw-wrap {
      padding-left: 4rem;
      padding-right: 4rem;
    }
  }

  .hiw-arrival__heading {
    font-size: calc(var(--font-heading-scale) * 2.8rem);
    margin: 0 0 1.2rem;
  }

  @media screen and (min-width: 750px) {
    .hiw-arrival__heading {
      font-size: calc(var(--font-heading-scale) * 3.6rem);
    }
  }

  .hiw-arrival__intro {
    font-size: 1.6rem;
    max-width: 60rem;
    margin: 0 auto 4.4rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.7);
  }

  .hiw-items {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.2rem;
    max-width: 90rem;
    margin: 0 auto;
  }

  @media screen and (min-width: 700px) {
    .hiw-items {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .hiw-item__media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    margin-bottom: 1.6rem;
    background-color: rgba(var(--color-foreground), 0.05);
  }

  .hiw-item__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hiw-item__title {
    font-size: calc(var(--font-heading-scale) * 1.7rem);
    margin: 0 0 0.5rem;
  }

  .hiw-item__text {
    font-size: 1.4rem;
    margin: 0;
    line-height: 1.55;
    color: rgba(var(--color-foreground), 0.65);
  }
{%- endstyle -%}

<div class="hiw-module">
  <div class="hiw-wrap">
    {%- if section.settings.heading != blank -%}
      <h2 class="hiw-heading hiw-arrival__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.intro != blank -%}
      <p class="hiw-body hiw-arrival__intro">{{ section.settings.intro }}</p>
    {%- endif -%}

    <div class="hiw-items">
      {%- for block in section.blocks -%}
        <div class="hiw-item" {{ block.shopify_attributes }}>
          <div class="hiw-item__media">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 720
                | image_tag:
                  width: block.settings.image.width,
                  height: block.settings.image.height,
                  sizes: '(min-width: 700px) 30vw, 100vw',
                  widths: '200, 360, 540, 720',
                  loading: 'lazy',
                  alt: block.settings.title
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          {%- if block.settings.title != blank -%}
            <h3 class="hiw-heading hiw-item__title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="hiw-body hiw-item__text">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "HIW · How it arrives",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "checkbox",
      "id": "background_tint",
      "label": "Tinted background",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Arrives like the heirloom it is"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro",
      "default": "From the moment it reaches your door, every detail is considered — protected, presented and ready to gift."
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Item"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Describe this part of the unboxing."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HIW · How it arrives",
      "blocks": [
        { "type": "item", "settings": { "title": "Gold-foil gift card", "text": "A hand-finished card, foil-stamped in gold, for your personal message." } },
        { "type": "item", "settings": { "title": "Linen wrap", "text": "The canvas is swathed in soft linen cloth to cushion every corner." } },
        { "type": "item", "settings": { "title": "Keepsake gift box", "text": "A rigid, museum-style box built to protect the piece — and worth keeping." } }
      ]
    }
  ]
}
{% endschema %}
