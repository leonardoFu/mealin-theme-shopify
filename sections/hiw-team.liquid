{%- style -%}
  #shopify-section-{{ section.id }} .hiw-module {
    padding: 6rem 0;
    text-align: center;
    color: rgb(var(--color-foreground));
    background-color: rgb(var(--color-background));
  }

  {%- if section.settings.background_tint -%}
    #shopify-section-{{ section.id }} .hiw-module {
      background-color: rgba(var(--color-foreground), 0.03);
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .hiw-heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: calc(var(--font-heading-scale) * 0.06rem);
    line-height: calc(1 + 0.3 / max(1, var(--font-heading-scale)));
  }

  #shopify-section-{{ section.id }} .hiw-body {
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  .hiw-wrap {
    max-width: 120rem;
    margin: 0 auto;
    padding-left: 1.6rem;
    padding-right: 1.6rem;
  }

  @media screen and (min-width: 750px) {
    .hiw-wrap {
      padding-left: 4rem;
      padding-right: 4rem;
    }
  }

  .hiw-team__lead {
    font-size: calc(var(--font-heading-scale) * 2rem);
    max-width: 64rem;
    margin: 0 auto 1.6rem;
    line-height: 1.4;
  }

  @media screen and (min-width: 750px) {
    .hiw-team__lead {
      font-size: calc(var(--font-heading-scale) * 2.4rem);
    }
  }

  .hiw-team__body {
    font-size: 1.6rem;
    max-width: 60rem;
    margin: 0 auto 4.4rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.7);
  }

  .hiw-painters {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.4rem;
    max-width: 80rem;
    margin: 0 auto 4rem;
  }

  @media screen and (min-width: 600px) {
    .hiw-painters {
      grid-template-columns: 1fr 1fr;
    }
  }

  .hiw-painter {
    padding: 3.2rem 2.2rem;
    border: 1px solid var(--maelin-border, rgba(0, 0, 0, 0.1));
    background-color: rgb(var(--color-background));
    text-align: center;
    transition: border-color 0.4s, transform 0.4s;
  }

  .hiw-painter:hover {
    border-color: var(--maelin-gold);
    transform: translateY(-3px);
  }

  .hiw-painter__frame {
    width: 11rem;
    height: 11rem;
    margin: 0 auto 2rem;
    border-radius: 50%;
    border: 1px solid var(--maelin-gold);
    padding: 0.5rem;
    background-color: rgb(var(--color-background));
  }

  .hiw-painter__photo {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
  }

  .hiw-painter__photo.placeholder {
    fill: rgba(var(--color-foreground), 0.3);
    background-color: rgba(var(--color-foreground), 0.04);
  }

  .hiw-painter__name {
    font-size: calc(var(--font-heading-scale) * 1.9rem);
    margin: 0 0 0.4rem;
  }

  .hiw-painter__school {
    font-family: var(--serif-elegant, 'Cormorant Garamond', serif);
    font-style: italic;
    font-size: 1.5rem;
    color: var(--maelin-gold-dark);
    margin: 0 0 1.2rem;
  }

  .hiw-painter__bio {
    font-size: 1.4rem;
    margin: 0 auto;
    max-width: 30rem;
    text-align: left;
    line-height: 1.65;
    color: rgba(var(--color-foreground), 0.65);
  }

  .hiw-mastery {
    font-size: 1.5rem;
    letter-spacing: 0.04em;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0;
  }

  .hiw-mastery strong {
    font-family: var(--serif-elegant, 'Cormorant Garamond', serif);
    font-style: italic;
    font-weight: 500;
    color: var(--maelin-gold-dark);
  }
{%- endstyle -%}

<div class="hiw-module">
  <div class="hiw-wrap">
    {%- if section.settings.lead != blank -%}
      <p class="hiw-heading hiw-team__lead">{{ section.settings.lead }}</p>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <p class="hiw-body hiw-team__body">{{ section.settings.body }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="hiw-painters">
        {%- for block in section.blocks -%}
          <div class="hiw-painter" {{ block.shopify_attributes }}>
            <div class="hiw-painter__frame">
              {%- if block.settings.photo != blank -%}
                {{
                  block.settings.photo
                  | image_url: width: 330
                  | image_tag:
                    loading: 'lazy',
                    widths: '110, 220, 330',
                    sizes: '11rem',
                    class: 'hiw-painter__photo',
                    alt: block.settings.name
                }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'hiw-painter__photo placeholder' }}
              {%- endif -%}
            </div>
            {%- if block.settings.name != blank -%}
              <h3 class="hiw-heading hiw-painter__name">{{ block.settings.name }}</h3>
            {%- endif -%}
            {%- if block.settings.school != blank -%}
              <p class="hiw-painter__school">{{ block.settings.school }}</p>
            {%- endif -%}
            {%- if block.settings.bio != blank -%}
              <p class="hiw-body hiw-painter__bio">{{ block.settings.bio }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.mastery != blank -%}
      <p class="hiw-body hiw-mastery">{{ section.settings.mastery }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "HIW · Meet the artists",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "checkbox",
      "id": "background_tint",
      "label": "Tinted background",
      "default": false
    },
    {
      "type": "text",
      "id": "lead",
      "label": "Lead line",
      "default": "Painted by German hands"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Your portrait is created by one of a small circle of classically trained painters working from studios across Germany — each a graduate of a leading German fine-art academy, with years of portrait work behind them. No factories, no filters, no print shops: just a brush, real oil paint and a steady, practised hand."
    },
    {
      "type": "text",
      "id": "mastery",
      "label": "Mastery line",
      "info": "Wrap words in <strong></strong> for the gold italic accent.",
      "default": "Fluent in both <strong>classical</strong> and <strong>modern</strong> schools — matched to the style you choose."
    }
  ],
  "blocks": [
    {
      "type": "painter",
      "name": "Painter",
      "settings": [
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Portrait photo",
          "info": "Square images work best (shown in a circular frame)."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Alex"
        },
        {
          "type": "text",
          "id": "school",
          "label": "School / academy",
          "default": "Academy of Fine Arts Nuremberg"
        },
        {
          "type": "textarea",
          "id": "bio",
          "label": "One-line bio",
          "default": "Blends classical realism with bold abstract expressionism to turn personal stories into timeless, gallery-quality art."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HIW · Meet the artists",
      "blocks": [
        { "type": "painter", "settings": { "name": "Alex", "school": "Academy of Fine Arts Nuremberg", "bio": "Blends classical realism with bold abstract expressionism to turn personal stories into timeless, gallery-quality art." } },
        { "type": "painter", "settings": { "name": "Lukas", "school": "State Academy of Fine Arts Stuttgart", "bio": "Combines geometric structure with soft textural layers to turn everyday memories into deeply structured, gallery-quality art." } },
        { "type": "painter", "settings": { "name": "Leon", "school": "Dresden Academy of Fine Arts", "bio": "Captures organic colour palettes and soft light to turn warm personal narratives into serene, gallery-quality art." } },
        { "type": "painter", "settings": { "name": "Mia", "school": "Kunstakademie Düsseldorf", "bio": "Infuses rich textural depth with meticulous modern brushwork to turn intimate human moments into powerful, gallery-quality art." } }
      ]
    }
  ]
}
{% endschema %}
