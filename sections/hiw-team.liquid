{%- style -%}
  #shopify-section-{{ section.id }} .hiw-module {
    padding: 6rem 0;
    text-align: center;
    color: rgb(var(--color-foreground));
    background-color: rgb(var(--color-background));
  }

  {%- if section.settings.background_tint -%}
    #shopify-section-{{ section.id }} .hiw-module {
      background-color: rgba(var(--color-foreground), 0.03);
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .hiw-heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: calc(var(--font-heading-scale) * 0.06rem);
    line-height: calc(1 + 0.3 / max(1, var(--font-heading-scale)));
  }

  #shopify-section-{{ section.id }} .hiw-body {
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  .hiw-wrap {
    max-width: 120rem;
    margin: 0 auto;
    padding-left: 1.6rem;
    padding-right: 1.6rem;
  }

  @media screen and (min-width: 750px) {
    .hiw-wrap {
      padding-left: 4rem;
      padding-right: 4rem;
    }
  }

  .hiw-team__lead {
    font-size: calc(var(--font-heading-scale) * 2rem);
    max-width: 64rem;
    margin: 0 auto 1.6rem;
    line-height: 1.4;
  }

  @media screen and (min-width: 750px) {
    .hiw-team__lead {
      font-size: calc(var(--font-heading-scale) * 2.4rem);
    }
  }

  .hiw-team__body {
    font-size: 1.6rem;
    max-width: 60rem;
    margin: 0 auto 4.4rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.7);
  }

  .hiw-origins {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.4rem;
    max-width: 72rem;
    margin: 0 auto 4rem;
  }

  @media screen and (min-width: 600px) {
    .hiw-origins {
      grid-template-columns: 1fr 1fr;
    }
  }

  .hiw-origin {
    padding: 3rem 2rem;
    border: 1px solid var(--maelin-border, rgba(0, 0, 0, 0.1));
    background-color: rgb(var(--color-background));
  }

  .hiw-origin__rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin: 0 0 1.4rem;
    color: var(--maelin-gold);
  }

  .hiw-origin__rule::before,
  .hiw-origin__rule::after {
    content: "";
    height: 1px;
    width: 2.8rem;
    background: var(--maelin-gold-accent);
    opacity: 0.7;
  }

  .hiw-origin__lozenge {
    font-size: 0.9rem;
    line-height: 1;
  }

  .hiw-origin__name {
    font-size: calc(var(--font-heading-scale) * 1.9rem);
    margin: 0 0 0.6rem;
  }

  .hiw-origin__text {
    font-size: 1.4rem;
    margin: 0;
    line-height: 1.55;
    color: rgba(var(--color-foreground), 0.65);
  }

  .hiw-mastery {
    font-size: 1.5rem;
    letter-spacing: 0.04em;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0;
  }

  .hiw-mastery strong {
    font-family: var(--serif-elegant, 'Cormorant Garamond', serif);
    font-style: italic;
    font-weight: 500;
    color: var(--maelin-gold-dark);
  }
{%- endstyle -%}

<div class="hiw-module">
  <div class="hiw-wrap">
    {%- if section.settings.lead != blank -%}
      <p class="hiw-heading hiw-team__lead">{{ section.settings.lead }}</p>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <p class="hiw-body hiw-team__body">{{ section.settings.body }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="hiw-origins">
        {%- for block in section.blocks -%}
          <div class="hiw-origin" {{ block.shopify_attributes }}>
            <div class="hiw-origin__rule" aria-hidden="true">
              <span class="hiw-origin__lozenge">&#9670;</span>
            </div>
            {%- if block.settings.name != blank -%}
              <h3 class="hiw-heading hiw-origin__name">{{ block.settings.name }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="hiw-body hiw-origin__text">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.mastery != blank -%}
      <p class="hiw-body hiw-mastery">{{ section.settings.mastery }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "HIW · Meet the artists",
  "tag": "section",
  "class": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "checkbox",
      "id": "background_tint",
      "label": "Tinted background",
      "default": false
    },
    {
      "type": "text",
      "id": "lead",
      "label": "Lead line",
      "default": "Painted by European hands"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Your portrait is created by one of a small circle of classically trained painters working from studios across Europe — each with years of fine-art portrait work behind them. No factories, no filters, no print shops: just a brush, real oil paint and a steady, practised hand."
    },
    {
      "type": "text",
      "id": "mastery",
      "label": "Mastery line",
      "info": "Wrap words in <strong></strong> for the gold italic accent.",
      "default": "Fluent in both <strong>classical</strong> and <strong>modern</strong> schools — matched to the style you choose."
    }
  ],
  "blocks": [
    {
      "type": "origin",
      "name": "Origin / studio",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Germany"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Atelier-trained painters with a precise, old-master approach to light and likeness."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HIW · Meet the artists",
      "blocks": [
        { "type": "origin", "settings": { "name": "Germany", "text": "Atelier-trained painters with a precise, old-master approach to light and likeness." } },
        { "type": "origin", "settings": { "name": "Sweden", "text": "A Nordic eye for quiet colour and the soft, living warmth of a gaze." } }
      ]
    }
  ]
}
{% endschema %}
