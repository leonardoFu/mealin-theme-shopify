{%- style -%}
  .memorial-promise {
    padding: clamp(4rem, 8vw, 7rem) 1.5rem;
    max-width: 72rem;
    margin: 0 auto;
  }

  .memorial-promise__label {
    font-family: 'Playfair Display', 'Georgia', 'Times New Roman', serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #999;
    text-align: center;
    margin: 0 0 1rem;
  }

  .memorial-promise__heading {
    font-family: 'Playfair Display', 'Georgia', 'Times New Roman', serif;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 400;
    text-align: center;
    color: #1a1a1a;
    margin: 0 0 3rem;
  }

  .memorial-promise__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    text-align: center;
  }

  @media (min-width: 750px) {
    .memorial-promise__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
    }
  }

  .memorial-promise__card {
    padding: 1rem;
  }

  .memorial-promise__icon {
    width: 3rem;
    height: 3rem;
    margin: 0 auto 1.25rem;
    display: block;
  }

  .memorial-promise__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .memorial-promise__card-title {
    font-family: 'Playfair Display', 'Georgia', 'Times New Roman', serif;
    font-size: 1.1rem;
    font-weight: 400;
    color: #1a1a1a;
    margin: 0 0 0.75rem;
  }

  .memorial-promise__card-text {
    font-size: 0.9rem;
    line-height: 1.7;
    color: #666;
    margin: 0;
  }
{%- endstyle -%}

<section class="memorial-promise" data-section-id="{{ section.id }}">
  {%- if section.settings.label != blank -%}
    <p class="memorial-promise__label">{{ section.settings.label }}</p>
  {%- endif -%}
  {%- if section.settings.heading != blank -%}
    <h2 class="memorial-promise__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="memorial-promise__grid">
      {%- for block in section.blocks -%}
        <div class="memorial-promise__card" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <div class="memorial-promise__icon">
              {{
                block.settings.icon
                | image_url: width: 96
                | image_tag:
                  widths: '48, 96',
                  sizes: '3rem',
                  loading: 'lazy'
              }}
            </div>
          {%- endif -%}
          {%- if block.settings.title != blank -%}
            <h3 class="memorial-promise__card-title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="memorial-promise__card-text">{{ block.settings.description }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Memorial Promise",
  "tag": "section",
  "class": "memorial-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "Our Promise"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Crafted with care, delivered with confidence"
    }
  ],
  "blocks": [
    {
      "type": "promise",
      "name": "Promise card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Get the likeness right"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "We refine every detail until you see your companion exactly as you remember them."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Memorial Promise",
      "blocks": [
        {
          "type": "promise",
          "settings": {
            "title": "Get the likeness right",
            "description": "We revise your sketch as many times as you need — no paint goes on until you see your companion exactly as you remember them."
          }
        },
        {
          "type": "promise",
          "settings": {
            "title": "Certificate of authenticity",
            "description": "Every portrait ships with a signed certificate verifying it as a genuine hand-painted original."
          }
        },
        {
          "type": "promise",
          "settings": {
            "title": "Progress updates",
            "description": "Watch your portrait come to life with photos at each stage — from sketch to final brushstroke."
          }
        }
      ]
    }
  ]
}
{% endschema %}
