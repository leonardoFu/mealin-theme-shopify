{%- style -%}
  .memorial-eyes {
    padding: clamp(4rem, 8vw, 7rem) 1.5rem;
    max-width: 72rem;
    margin: 0 auto;
  }

  .memorial-eyes__label {
    font-family: 'Playfair Display', 'Georgia', 'Times New Roman', serif;
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #999;
    text-align: center;
    margin: 0 0 1rem;
  }

  .memorial-eyes__heading {
    font-family: 'Playfair Display', 'Georgia', 'Times New Roman', serif;
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 400;
    text-align: center;
    color: #1a1a1a;
    margin: 0 0 3rem;
  }

  .memorial-eyes__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 750px) {
    .memorial-eyes__grid {
      grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
      gap: 2.5rem;
    }
  }

  .memorial-eyes__card {
    text-align: center;
  }

  .memorial-eyes__images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    margin-bottom: 1.25rem;
  }

  .memorial-eyes__images img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 2px;
  }

  .memorial-eyes__pet-name {
    font-family: 'Playfair Display', 'Georgia', 'Times New Roman', serif;
    font-size: 1.1rem;
    font-style: italic;
    color: #1a1a1a;
    margin: 0 0 0.35rem;
  }

  .memorial-eyes__caption {
    font-size: 0.85rem;
    color: #777;
    line-height: 1.5;
    margin: 0;
  }
{%- endstyle -%}

<section class="memorial-eyes" data-section-id="{{ section.id }}">
  {%- if section.settings.label != blank -%}
    <p class="memorial-eyes__label">{{ section.settings.label }}</p>
  {%- endif -%}
  {%- if section.settings.heading != blank -%}
    <h2 class="memorial-eyes__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="memorial-eyes__grid">
      {%- for block in section.blocks -%}
        <div class="memorial-eyes__card" {{ block.shopify_attributes }}>
          <div class="memorial-eyes__images">
            {%- if block.settings.photo_original != blank -%}
              {{
                block.settings.photo_original
                | image_url: width: 800
                | image_tag:
                  widths: '300, 500, 800',
                  sizes: '(min-width: 750px) 25vw, 45vw',
                  loading: 'lazy',
                  alt: block.settings.pet_name | append: ' — original photo'
              }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag }}
            {%- endif -%}
            {%- if block.settings.photo_painting != blank -%}
              {{
                block.settings.photo_painting
                | image_url: width: 800
                | image_tag:
                  widths: '300, 500, 800',
                  sizes: '(min-width: 750px) 25vw, 45vw',
                  loading: 'lazy',
                  alt: block.settings.pet_name | append: ' — hand-painted portrait'
              }}
            {%- else -%}
              {{ 'image' | placeholder_svg_tag }}
            {%- endif -%}
          </div>
          {%- if block.settings.pet_name != blank -%}
            <p class="memorial-eyes__pet-name">{{ block.settings.pet_name }}</p>
          {%- endif -%}
          {%- if block.settings.caption != blank -%}
            <p class="memorial-eyes__caption">{{ block.settings.caption }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Memorial Eyes",
  "tag": "section",
  "class": "memorial-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Section label",
      "default": "The Eyes"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "We paint the soul you see in their eyes"
    }
  ],
  "blocks": [
    {
      "type": "comparison",
      "name": "Comparison card",
      "settings": [
        {
          "type": "image_picker",
          "id": "photo_original",
          "label": "Original photo"
        },
        {
          "type": "image_picker",
          "id": "photo_painting",
          "label": "Painted portrait"
        },
        {
          "type": "text",
          "id": "pet_name",
          "label": "Pet name",
          "default": "Buddy"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption",
          "default": "Every wrinkle, every spark of mischief — captured in oil."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Memorial Eyes",
      "blocks": [
        { "type": "comparison" },
        { "type": "comparison" },
        { "type": "comparison" }
      ]
    }
  ]
}
{% endschema %}
