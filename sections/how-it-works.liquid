{%- style -%}
  .hiw-section {
    --hiw-max-width: 120rem;
    --hiw-gutter: 1.6rem;
    color: rgb(var(--color-foreground));
    background-color: rgb(var(--color-background));
  }

  @media screen and (min-width: 750px) {
    .hiw-section {
      --hiw-gutter: 4rem;
    }
  }

  .hiw-wrap {
    max-width: var(--hiw-max-width);
    margin: 0 auto;
    padding-left: var(--hiw-gutter);
    padding-right: var(--hiw-gutter);
  }

  .hiw-heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: calc(var(--font-heading-scale) * 0.06rem);
    line-height: calc(1 + 0.3 / max(1, var(--font-heading-scale)));
  }

  .hiw-body {
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  /* 01 · Hero */
  .hiw-hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    overflow: hidden;
    text-align: center;
  }

  .hiw-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hiw-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hiw-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    z-index: 1;
  }

  .hiw-hero__content {
    position: relative;
    z-index: 2;
    padding: 4rem var(--hiw-gutter);
    color: #fff;
    max-width: 72rem;
  }

  .hiw-hero__headline {
    font-size: calc(var(--font-heading-scale) * 3.2rem);
    margin: 0 0 1.2rem;
  }

  @media screen and (min-width: 750px) {
    .hiw-hero__headline {
      font-size: calc(var(--font-heading-scale) * 5rem);
    }
  }

  .hiw-hero__subline {
    font-size: 1.6rem;
    margin: 0;
    opacity: 0.9;
  }

  @media screen and (min-width: 750px) {
    .hiw-hero__subline {
      font-size: 1.8rem;
    }
  }

  /* 02 · Your journey (customer steps) */
  .hiw-journey {
    padding: 6rem 0;
    text-align: center;
  }

  .hiw-journey__heading {
    font-size: calc(var(--font-heading-scale) * 2.8rem);
    margin: 0 0 0.8rem;
  }

  @media screen and (min-width: 750px) {
    .hiw-journey__heading {
      font-size: calc(var(--font-heading-scale) * 3.6rem);
    }
  }

  .hiw-journey__intro {
    font-size: 1.6rem;
    margin: 0 auto 4.4rem;
    max-width: 60rem;
    color: rgba(var(--color-foreground), 0.7);
  }

  .hiw-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4.8rem;
    max-width: 100rem;
    margin: 0 auto;
    position: relative;
  }

  @media screen and (min-width: 750px) {
    .hiw-steps {
      grid-template-columns: repeat(4, 1fr);
      gap: 3.6rem;
    }

    .hiw-steps::before {
      content: '';
      position: absolute;
      top: 2.7rem;
      left: 12%;
      right: 12%;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--maelin-gold-muted, var(--maelin-gold-accent)), var(--maelin-gold-muted, var(--maelin-gold-accent)), transparent);
    }
  }

  .hiw-step {
    text-align: center;
    position: relative;
  }

  .hiw-step__icon {
    width: 5.4rem;
    height: 5.4rem;
    border: 1px solid var(--maelin-gold);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--maelin-gold);
    margin: 0 auto 2.4rem;
    position: relative;
    z-index: 1;
    background-color: rgb(var(--color-background));
    transition: all 0.4s;
  }

  .hiw-step__icon svg {
    width: 1.8rem;
    height: 1.8rem;
    fill: var(--maelin-gold);
    transition: fill 0.4s;
  }

  .hiw-step:hover .hiw-step__icon {
    background: var(--maelin-gold);
  }

  .hiw-step:hover .hiw-step__icon svg {
    fill: #fff;
  }

  .hiw-step__title {
    font-size: calc(var(--font-heading-scale) * 1.7rem);
    margin: 0 0 1rem;
  }

  .hiw-step__text {
    font-size: 1.4rem;
    margin: 0;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.65);
  }

  /* 03 · Behind the easel (8 production stages) */
  .hiw-process {
    padding: 6rem 0;
    text-align: center;
    background-color: rgba(var(--color-foreground), 0.03);
  }

  .hiw-process__heading {
    font-size: calc(var(--font-heading-scale) * 2.8rem);
    margin: 0 0 1.2rem;
  }

  @media screen and (min-width: 750px) {
    .hiw-process__heading {
      font-size: calc(var(--font-heading-scale) * 3.6rem);
    }
  }

  .hiw-process__caption-area {
    font-size: 1.4rem;
    color: rgba(var(--color-foreground), 0.6);
    margin: 0 0 3.2rem;
    font-style: italic;
  }

  .hiw-process__video {
    max-width: 72rem;
    margin: 0 auto 3.2rem;
  }

  .hiw-process__video iframe {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
  }

  .hiw-timeline {
    max-width: 58rem;
    margin: 1.2rem auto 0;
    text-align: left;
  }

  .hiw-tstep {
    display: grid;
    grid-template-columns: 5.6rem 1fr;
    column-gap: 2rem;
    align-items: stretch;
  }

  .hiw-tstep__rail {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hiw-tstep__num {
    font-family: var(--serif, 'Playfair Display', serif);
    font-size: 2rem;
    line-height: 1;
    color: var(--maelin-gold-dark);
    padding-top: 0.2rem;
  }

  .hiw-tstep__line {
    flex: 1 1 auto;
    width: 1px;
    margin: 0.9rem 0 0;
    background: var(--maelin-gold-accent);
    opacity: 0.45;
  }

  .hiw-tstep:last-child .hiw-tstep__line {
    display: none;
  }

  .hiw-tstep__body {
    padding-bottom: 3rem;
  }

  .hiw-tstep:last-child .hiw-tstep__body {
    padding-bottom: 0;
  }

  .hiw-tstep__label {
    font-size: calc(var(--font-heading-scale) * 1.7rem);
    margin: 0 0 0.4rem;
  }

  .hiw-tstep__caption {
    font-size: 1.4rem;
    margin: 0;
    line-height: 1.55;
    color: rgba(var(--color-foreground), 0.65);
  }

  /* 04 · Meet the artists (team & provenance) */
  .hiw-team {
    padding: 6rem 0;
    text-align: center;
  }

  .hiw-team__lead {
    font-size: calc(var(--font-heading-scale) * 2rem);
    max-width: 64rem;
    margin: 0 auto 1.6rem;
    line-height: 1.4;
  }

  @media screen and (min-width: 750px) {
    .hiw-team__lead {
      font-size: calc(var(--font-heading-scale) * 2.4rem);
    }
  }

  .hiw-team__body {
    font-size: 1.6rem;
    max-width: 60rem;
    margin: 0 auto 4.4rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.7);
  }

  .hiw-origins {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.4rem;
    max-width: 72rem;
    margin: 0 auto 4rem;
  }

  @media screen and (min-width: 600px) {
    .hiw-origins {
      grid-template-columns: 1fr 1fr;
    }
  }

  .hiw-origin {
    padding: 3rem 2rem;
    border: 1px solid var(--maelin-border, rgba(0, 0, 0, 0.1));
    background-color: rgb(var(--color-background));
  }

  .hiw-origin__rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin: 0 0 1.4rem;
    color: var(--maelin-gold);
  }

  .hiw-origin__rule::before,
  .hiw-origin__rule::after {
    content: "";
    height: 1px;
    width: 2.8rem;
    background: var(--maelin-gold-accent);
    opacity: 0.7;
  }

  .hiw-origin__lozenge {
    font-size: 0.9rem;
    line-height: 1;
  }

  .hiw-origin__name {
    font-size: calc(var(--font-heading-scale) * 1.9rem);
    margin: 0 0 0.6rem;
  }

  .hiw-origin__text {
    font-size: 1.4rem;
    margin: 0;
    line-height: 1.55;
    color: rgba(var(--color-foreground), 0.65);
  }

  .hiw-mastery {
    font-size: 1.5rem;
    letter-spacing: 0.04em;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0;
  }

  .hiw-mastery strong {
    font-family: var(--serif-elegant, 'Cormorant Garamond', serif);
    font-style: italic;
    font-weight: 500;
    color: var(--maelin-gold-dark);
  }

  /* 05 · How it arrives (packaging & frames) */
  .hiw-arrival {
    padding: 6rem 0;
    text-align: center;
    background-color: rgba(var(--color-foreground), 0.03);
  }

  .hiw-arrival__heading {
    font-size: calc(var(--font-heading-scale) * 2.8rem);
    margin: 0 0 1.2rem;
  }

  @media screen and (min-width: 750px) {
    .hiw-arrival__heading {
      font-size: calc(var(--font-heading-scale) * 3.6rem);
    }
  }

  .hiw-arrival__intro {
    font-size: 1.6rem;
    max-width: 60rem;
    margin: 0 auto 4.4rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.7);
  }

  .hiw-items {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.2rem;
    max-width: 90rem;
    margin: 0 auto;
  }

  @media screen and (min-width: 700px) {
    .hiw-items {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .hiw-item__media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    margin-bottom: 1.6rem;
    background-color: rgba(var(--color-foreground), 0.05);
  }

  .hiw-item__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hiw-item__title {
    font-size: calc(var(--font-heading-scale) * 1.7rem);
    margin: 0 0 0.5rem;
  }

  .hiw-item__text {
    font-size: 1.4rem;
    margin: 0;
    line-height: 1.55;
    color: rgba(var(--color-foreground), 0.65);
  }

  /* 06 · CTA */
  .hiw-cta {
    padding: 8rem 0;
    text-align: center;
  }

  .hiw-cta__headline {
    font-size: calc(var(--font-heading-scale) * 2.4rem);
    margin: 0 0 2.4rem;
  }

  @media screen and (min-width: 750px) {
    .hiw-cta__headline {
      font-size: calc(var(--font-heading-scale) * 3.2rem);
    }
  }

  .hiw-cta__subline {
    font-size: 1.4rem;
    margin: 2rem 0 0;
    color: rgba(var(--color-foreground), 0.6);
  }
{%- endstyle -%}

<div class="hiw-section" id="HowItWorks-{{ section.id }}">

  {%- comment -%} 01 · HERO {%- endcomment -%}
  <div class="hiw-hero">
    <div class="hiw-hero__media">
      {%- if section.settings.hero_image != blank -%}
        {{
          section.settings.hero_image
          | image_url: width: 3840
          | image_tag:
            width: section.settings.hero_image.width,
            height: section.settings.hero_image.height,
            sizes: '100vw',
            widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
            loading: 'eager',
            fetchpriority: 'high'
        }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
    <div class="hiw-hero__overlay"></div>
    <div class="hiw-hero__content">
      <h1 class="hiw-heading hiw-hero__headline">{{ section.settings.hero_headline }}</h1>
      {%- if section.settings.hero_subline != blank -%}
        <p class="hiw-body hiw-hero__subline">{{ section.settings.hero_subline }}</p>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} 02 · YOUR JOURNEY (customer steps) {%- endcomment -%}
  <div class="hiw-journey">
    <div class="hiw-wrap">
      <h2 class="hiw-heading hiw-journey__heading">{{ section.settings.journey_heading }}</h2>
      {%- if section.settings.journey_intro != blank -%}
        <p class="hiw-body hiw-journey__intro">{{ section.settings.journey_intro }}</p>
      {%- endif -%}
      <div class="hiw-steps">
        {%- for i in (1..4) -%}
          {%- liquid
            case i
              when 1
                assign j_icon = section.settings.journey1_icon
                assign j_title = section.settings.journey1_title
                assign j_text = section.settings.journey1_text
              when 2
                assign j_icon = section.settings.journey2_icon
                assign j_title = section.settings.journey2_title
                assign j_text = section.settings.journey2_text
              when 3
                assign j_icon = section.settings.journey3_icon
                assign j_title = section.settings.journey3_title
                assign j_text = section.settings.journey3_text
              when 4
                assign j_icon = section.settings.journey4_icon
                assign j_title = section.settings.journey4_title
                assign j_text = section.settings.journey4_text
            endcase
          -%}
          {%- if j_title != blank -%}
            <div class="hiw-step">
              <div class="hiw-step__icon" aria-hidden="true">
                {%- case j_icon -%}
                  {%- when 'upload' -%}{% render 'icon-upload' %}
                  {%- when 'palette' -%}{% render 'icon-palette' %}
                  {%- when 'brush' -%}{% render 'icon-brush' %}
                  {%- when 'gift' -%}{% render 'icon-gift' %}
                {%- endcase -%}
              </div>
              <h3 class="hiw-heading hiw-step__title">{{ j_title }}</h3>
              {%- if j_text != blank -%}
                <p class="hiw-body hiw-step__text">{{ j_text }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} 03 · BEHIND THE EASEL (8 production stages) {%- endcomment -%}
  <div class="hiw-process">
    <div class="hiw-wrap">
      <h2 class="hiw-heading hiw-process__heading">{{ section.settings.process_heading }}</h2>
      {%- if section.settings.process_caption != blank -%}
        <p class="hiw-body hiw-process__caption-area">{{ section.settings.process_caption }}</p>
      {%- endif -%}

      {%- if section.settings.process_video_url != blank -%}
        <div class="hiw-process__video">
          <iframe
            src="{{ section.settings.process_video_url }}"
            allow="autoplay; encrypted-media"
            allowfullscreen
            loading="lazy"
            title="Process video"
          ></iframe>
        </div>
      {%- endif -%}

      <div class="hiw-timeline">
        {%- for i in (1..8) -%}
          {%- liquid
            case i
              when 1
                assign step_label = section.settings.step1_label
                assign step_caption = section.settings.step1_caption
              when 2
                assign step_label = section.settings.step2_label
                assign step_caption = section.settings.step2_caption
              when 3
                assign step_label = section.settings.step3_label
                assign step_caption = section.settings.step3_caption
              when 4
                assign step_label = section.settings.step4_label
                assign step_caption = section.settings.step4_caption
              when 5
                assign step_label = section.settings.step5_label
                assign step_caption = section.settings.step5_caption
              when 6
                assign step_label = section.settings.step6_label
                assign step_caption = section.settings.step6_caption
              when 7
                assign step_label = section.settings.step7_label
                assign step_caption = section.settings.step7_caption
              when 8
                assign step_label = section.settings.step8_label
                assign step_caption = section.settings.step8_caption
            endcase
            assign step_num = i | prepend: '0'
          -%}
          {%- if step_label != blank -%}
            <div class="hiw-tstep">
              <div class="hiw-tstep__rail" aria-hidden="true">
                <span class="hiw-tstep__num">{{ step_num }}</span>
                <span class="hiw-tstep__line"></span>
              </div>
              <div class="hiw-tstep__body">
                <h3 class="hiw-heading hiw-tstep__label">{{ step_label }}</h3>
                {%- if step_caption != blank -%}
                  <p class="hiw-body hiw-tstep__caption">{{ step_caption }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} 04 · MEET THE ARTISTS (team & provenance) {%- endcomment -%}
  <div class="hiw-team">
    <div class="hiw-wrap">
      <p class="hiw-heading hiw-team__lead">{{ section.settings.team_lead }}</p>
      {%- if section.settings.team_body != blank -%}
        <p class="hiw-body hiw-team__body">{{ section.settings.team_body }}</p>
      {%- endif -%}
      <div class="hiw-origins">
        {%- for i in (1..2) -%}
          {%- liquid
            case i
              when 1
                assign origin_name = section.settings.origin1_name
                assign origin_text = section.settings.origin1_text
              when 2
                assign origin_name = section.settings.origin2_name
                assign origin_text = section.settings.origin2_text
            endcase
          -%}
          {%- if origin_name != blank -%}
            <div class="hiw-origin">
              <div class="hiw-origin__rule" aria-hidden="true">
                <span class="hiw-origin__lozenge">&#9670;</span>
              </div>
              <h3 class="hiw-heading hiw-origin__name">{{ origin_name }}</h3>
              {%- if origin_text != blank -%}
                <p class="hiw-body hiw-origin__text">{{ origin_text }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      {%- if section.settings.team_mastery != blank -%}
        <p class="hiw-body hiw-mastery">{{ section.settings.team_mastery }}</p>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} 05 · HOW IT ARRIVES (packaging & frames) {%- endcomment -%}
  <div class="hiw-arrival">
    <div class="hiw-wrap">
      <h2 class="hiw-heading hiw-arrival__heading">{{ section.settings.arrival_heading }}</h2>
      {%- if section.settings.arrival_intro != blank -%}
        <p class="hiw-body hiw-arrival__intro">{{ section.settings.arrival_intro }}</p>
      {%- endif -%}

      <div class="hiw-items">
        {%- for i in (1..3) -%}
          {%- liquid
            case i
              when 1
                assign item_image = section.settings.item1_image
                assign item_title = section.settings.item1_title
                assign item_text = section.settings.item1_text
              when 2
                assign item_image = section.settings.item2_image
                assign item_title = section.settings.item2_title
                assign item_text = section.settings.item2_text
              when 3
                assign item_image = section.settings.item3_image
                assign item_title = section.settings.item3_title
                assign item_text = section.settings.item3_text
            endcase
          -%}
          {%- if item_title != blank -%}
            <div class="hiw-item">
              <div class="hiw-item__media">
                {%- if item_image != blank -%}
                  {{
                    item_image
                    | image_url: width: 720
                    | image_tag:
                      width: item_image.width,
                      height: item_image.height,
                      sizes: '(min-width: 700px) 30vw, 100vw',
                      widths: '200, 360, 540, 720',
                      loading: 'lazy',
                      alt: item_title
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              <h3 class="hiw-heading hiw-item__title">{{ item_title }}</h3>
              {%- if item_text != blank -%}
                <p class="hiw-body hiw-item__text">{{ item_text }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>

  {%- comment -%} 06 · CLOSING CTA {%- endcomment -%}
  <div class="hiw-cta">
    <div class="hiw-wrap">
      <h2 class="hiw-heading hiw-cta__headline">{{ section.settings.cta_headline }}</h2>
      <a href="{{ section.settings.cta_url | default: '#' }}" class="button">
        {{ section.settings.cta_button_label }}
      </a>
      {%- if section.settings.cta_subline != blank -%}
        <p class="hiw-body hiw-cta__subline">{{ section.settings.cta_subline }}</p>
      {%- endif -%}
    </div>
  </div>

</div>

{% schema %}
{
  "name": "How It Works",
  "tag": "section",
  "class": "how-it-works-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image",
      "info": "Recommended: 2000 × 1000 px or larger."
    },
    {
      "type": "text",
      "id": "hero_headline",
      "label": "Headline",
      "default": "From your photo to a painting made to outlive us all."
    },
    {
      "type": "text",
      "id": "hero_subline",
      "label": "Subline",
      "default": "Every commission, step by step"
    },
    {
      "type": "header",
      "content": "Your journey (customer steps)"
    },
    {
      "type": "text",
      "id": "journey_heading",
      "label": "Heading",
      "default": "Your journey"
    },
    {
      "type": "textarea",
      "id": "journey_intro",
      "label": "Intro line",
      "default": "A guided path from your cherished photograph to a hand-painted heirloom — with up to three free revisions, so the final piece is exactly right."
    },
    {
      "type": "select",
      "id": "journey1_icon",
      "label": "Step 1 icon",
      "options": [
        { "value": "upload", "label": "Upload / Photo" },
        { "value": "palette", "label": "Palette / Style" },
