{%- style -%}
  .craft-section {
    --craft-max-width: 120rem;
    --craft-gutter: 1.6rem;
    color: rgb(var(--color-foreground));
    background-color: rgb(var(--color-background));
  }

  @media screen and (min-width: 750px) {
    .craft-section {
      --craft-gutter: 4rem;
    }
  }

  .craft-wrap {
    max-width: var(--craft-max-width);
    margin: 0 auto;
    padding-left: var(--craft-gutter);
    padding-right: var(--craft-gutter);
  }

  .craft-heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: calc(var(--font-heading-scale) * 0.06rem);
    line-height: calc(1 + 0.3 / max(1, var(--font-heading-scale)));
  }

  .craft-body {
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  /* 01 · Hero */
  .craft-hero {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 70vh;
    overflow: hidden;
    text-align: center;
  }

  .craft-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .craft-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .craft-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    z-index: 1;
  }

  .craft-hero__content {
    position: relative;
    z-index: 2;
    padding: 4rem var(--craft-gutter);
    color: #fff;
    max-width: 72rem;
  }

  .craft-hero__headline {
    font-size: calc(var(--font-heading-scale) * 3.2rem);
    margin: 0 0 1.2rem;
  }

  @media screen and (min-width: 750px) {
    .craft-hero__headline {
      font-size: calc(var(--font-heading-scale) * 5rem);
    }
  }

  .craft-hero__subline {
    font-size: 1.6rem;
    margin: 0;
    opacity: 0.9;
  }

  @media screen and (min-width: 750px) {
    .craft-hero__subline {
      font-size: 1.8rem;
    }
  }

  /* 02 · Real-paint anchor */
  .craft-anchor {
    padding: 6rem 0;
    text-align: center;
  }

  .craft-anchor__heading {
    font-size: calc(var(--font-heading-scale) * 2.8rem);
    margin: 0 0 0.8rem;
  }

  @media screen and (min-width: 750px) {
    .craft-anchor__heading {
      font-size: calc(var(--font-heading-scale) * 3.6rem);
    }
  }

  .craft-anchor__intro {
    font-size: 1.6rem;
    margin: 0 0 4rem;
    color: rgba(var(--color-foreground), 0.7);
  }

  .craft-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.2rem;
    max-width: 96rem;
    margin: 0 auto;
  }

  @media screen and (min-width: 750px) {
    .craft-cards {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .craft-card {
    text-align: center;
    padding: 2rem 1.6rem;
  }

  .craft-card__icon {
    width: 4.8rem;
    height: 4.8rem;
    margin: 0 auto 1.6rem;
  }

  .craft-card__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .craft-card__title {
    font-size: calc(var(--font-heading-scale) * 1.8rem);
    margin: 0 0 0.6rem;
  }

  .craft-card__text {
    font-size: 1.4rem;
    margin: 0;
    color: rgba(var(--color-foreground), 0.7);
  }

  /* 03 · Process proof */
  .craft-process {
    padding: 6rem 0;
    text-align: center;
    background-color: rgba(var(--color-foreground), 0.03);
  }

  .craft-process__heading {
    font-size: calc(var(--font-heading-scale) * 2.8rem);
    margin: 0 0 1.2rem;
  }

  @media screen and (min-width: 750px) {
    .craft-process__heading {
      font-size: calc(var(--font-heading-scale) * 3.6rem);
    }
  }

  .craft-process__caption-area {
    font-size: 1.4rem;
    color: rgba(var(--color-foreground), 0.6);
    margin: 0 0 3.2rem;
    font-style: italic;
  }

  .craft-process__video {
    max-width: 72rem;
    margin: 0 auto 3.2rem;
  }

  .craft-process__video iframe {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
  }

  .craft-timeline {
    max-width: 58rem;
    margin: 1.2rem auto 0;
    text-align: left;
  }

  .craft-step {
    display: grid;
    grid-template-columns: 5.6rem 1fr;
    column-gap: 2rem;
    align-items: stretch;
  }

  .craft-step__rail {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .craft-step__num {
    font-family: var(--serif, 'Playfair Display', serif);
    font-size: 2rem;
    line-height: 1;
    color: var(--maelin-gold-dark);
    padding-top: 0.2rem;
  }

  .craft-step__line {
    flex: 1 1 auto;
    width: 1px;
    margin: 0.9rem 0 0;
    background: var(--maelin-gold-accent);
    opacity: 0.45;
  }

  .craft-step:last-child .craft-step__line {
    display: none;
  }

  .craft-step__body {
    padding-bottom: 3rem;
  }

  .craft-step:last-child .craft-step__body {
    padding-bottom: 0;
  }

  .craft-step__label {
    font-size: calc(var(--font-heading-scale) * 1.7rem);
    margin: 0 0 0.4rem;
  }

  .craft-step__caption {
    font-size: 1.4rem;
    margin: 0;
    line-height: 1.55;
    color: rgba(var(--color-foreground), 0.65);
  }

  /* 04 · The painters (team & provenance) */
  .craft-team {
    padding: 6rem 0;
    text-align: center;
  }

  .craft-team__lead {
    font-size: calc(var(--font-heading-scale) * 2rem);
    max-width: 64rem;
    margin: 0 auto 1.6rem;
    line-height: 1.4;
  }

  @media screen and (min-width: 750px) {
    .craft-team__lead {
      font-size: calc(var(--font-heading-scale) * 2.4rem);
    }
  }

  .craft-team__body {
    font-size: 1.6rem;
    max-width: 60rem;
    margin: 0 auto 4.4rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.7);
  }

  .craft-origins {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.4rem;
    max-width: 72rem;
    margin: 0 auto 4rem;
  }

  @media screen and (min-width: 600px) {
    .craft-origins {
      grid-template-columns: 1fr 1fr;
    }
  }

  .craft-origin {
    padding: 3rem 2rem;
    border: 1px solid var(--maelin-border, rgba(0, 0, 0, 0.1));
    background-color: rgb(var(--color-background));
  }

  .craft-origin__rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin: 0 0 1.4rem;
    color: var(--maelin-gold);
  }

  .craft-origin__rule::before,
  .craft-origin__rule::after {
    content: "";
    height: 1px;
    width: 2.8rem;
    background: var(--maelin-gold-accent);
    opacity: 0.7;
  }

  .craft-origin__lozenge {
    font-size: 0.9rem;
    line-height: 1;
  }

  .craft-origin__name {
    font-size: calc(var(--font-heading-scale) * 1.9rem);
    margin: 0 0 0.6rem;
  }

  .craft-origin__text {
    font-size: 1.4rem;
    margin: 0;
    line-height: 1.55;
    color: rgba(var(--color-foreground), 0.65);
  }

  .craft-mastery {
    font-size: 1.5rem;
    letter-spacing: 0.04em;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0;
  }

  .craft-mastery strong {
    font-family: var(--serif-elegant, 'Cormorant Garamond', serif);
    font-style: italic;
    font-weight: 500;
    color: var(--maelin-gold-dark);
  }

  /* 05 · Materials */
  .craft-materials {
    padding: 6rem 0;
    text-align: center;
    background-color: rgba(var(--color-foreground), 0.03);
  }

  .craft-materials__heading {
    font-size: calc(var(--font-heading-scale) * 2.8rem);
    margin: 0 0 2rem;
  }

  @media screen and (min-width: 750px) {
    .craft-materials__heading {
      font-size: calc(var(--font-heading-scale) * 3.6rem);
    }
  }

  .craft-materials__body {
    font-size: 1.6rem;
    max-width: 64rem;
    margin: 0 auto;
    line-height: 1.8;
    color: rgba(var(--color-foreground), 0.75);
  }

  .craft-materials__body p {
    margin: 0;
  }

  /* 05b · The arrival (packaging & frames) */
  .craft-arrival {
    padding: 6rem 0;
    text-align: center;
  }

  .craft-arrival__heading {
    font-size: calc(var(--font-heading-scale) * 2.8rem);
    margin: 0 0 1.2rem;
  }

  @media screen and (min-width: 750px) {
    .craft-arrival__heading {
      font-size: calc(var(--font-heading-scale) * 3.6rem);
    }
  }

  .craft-arrival__intro {
    font-size: 1.6rem;
    max-width: 60rem;
    margin: 0 auto 4.4rem;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.7);
  }

  .craft-items {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.2rem;
    max-width: 90rem;
    margin: 0 auto;
  }

  @media screen and (min-width: 700px) {
    .craft-items {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .craft-item__media {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    margin-bottom: 1.6rem;
    background-color: rgba(var(--color-foreground), 0.05);
  }

  .craft-item__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .craft-item__title {
    font-size: calc(var(--font-heading-scale) * 1.7rem);
    margin: 0 0 0.5rem;
  }

  .craft-item__text {
    font-size: 1.4rem;
    margin: 0;
    line-height: 1.55;
    color: rgba(var(--color-foreground), 0.65);
  }

  /* 06 · CTA */
  .craft-cta {
    padding: 8rem 0;
    text-align: center;
  }

  .craft-cta__headline {
    font-size: calc(var(--font-heading-scale) * 2.4rem);
    margin: 0 0 2.4rem;
  }

  @media screen and (min-width: 750px) {
    .craft-cta__headline {
      font-size: calc(var(--font-heading-scale) * 3.2rem);
    }
  }

  .craft-cta__subline {
    font-size: 1.4rem;
    margin: 2rem 0 0;
    color: rgba(var(--color-foreground), 0.6);
  }
{%- endstyle -%}

<div class="craft-section" id="OurCraft-{{ section.id }}">

  {%- comment -%} 01 · HERO {%- endcomment -%}
  <div class="craft-hero">
    <div class="craft-hero__media">
      {%- if section.settings.hero_image != blank -%}
        {{
          section.settings.hero_image
          | image_url: width: 3840
          | image_tag:
            width: section.settings.hero_image.width,
            height: section.settings.hero_image.height,
            sizes: '100vw',
            widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
            loading: 'eager',
            fetchpriority: 'high'
        }}
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
    <div class="craft-hero__overlay"></div>
    <div class="craft-hero__content">
      <h1 class="craft-heading craft-hero__headline">{{ section.settings.hero_headline }}</h1>
      {%- if section.settings.hero_subline != blank -%}
        <p class="craft-body craft-hero__subline">{{ section.settings.hero_subline }}</p>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} 02 · THE REAL-PAINT ANCHOR {%- endcomment -%}
  <div class="craft-anchor">
    <div class="craft-wrap">
      <h2 class="craft-heading craft-anchor__heading">{{ section.settings.anchor_heading }}</h2>
      {%- if section.settings.anchor_intro != blank -%}
        <p class="craft-body craft-anchor__intro">{{ section.settings.anchor_intro }}</p>
      {%- endif -%}
      <div class="craft-cards">
        {%- for i in (1..3) -%}
          {%- liquid
            case i
              when 1
                assign card_icon  = section.settings.anchor_card1_icon
                assign card_title = section.settings.anchor_card1_title
                assign card_text  = section.settings.anchor_card1_text
              when 2
                assign card_icon  = section.settings.anchor_card2_icon
                assign card_title = section.settings.anchor_card2_title
                assign card_text  = section.settings.anchor_card2_text
              when 3
                assign card_icon  = section.settings.anchor_card3_icon
                assign card_title = section.settings.anchor_card3_title
                assign card_text  = section.settings.anchor_card3_text
            endcase
          -%}
          <div class="craft-card">
            {%- if card_icon != blank -%}
              <div class="craft-card__icon">
                {{ card_icon | image_url: width: 96 | image_tag: width: card_icon.width, height: card_icon.height, loading: 'lazy' }}
              </div>
            {%- endif -%}
            <h3 class="craft-heading craft-card__title">{{ card_title }}</h3>
            <p class="craft-body craft-card__text">{{ card_text }}</p>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} 03 · PROCESS PROOF {%- endcomment -%}
  <div class="craft-process">
    <div class="craft-wrap">
      <h2 class="craft-heading craft-process__heading">{{ section.settings.process_heading }}</h2>
      {%- if section.settings.process_caption != blank -%}
        <p class="craft-body craft-process__caption-area">{{ section.settings.process_caption }}</p>
      {%- endif -%}

      {%- if section.settings.process_video_url != blank -%}
        <div class="craft-process__video">
          <iframe
            src="{{ section.settings.process_video_url }}"
            allow="autoplay; encrypted-media"
            allowfullscreen
            loading="lazy"
            title="Process video"
          ></iframe>
        </div>
      {%- endif -%}

      <div class="craft-timeline">
        {%- for i in (1..8) -%}
          {%- liquid
            case i
              when 1
                assign step_label = section.settings.step1_label
                assign step_caption = section.settings.step1_caption
              when 2
                assign step_label = section.settings.step2_label
                assign step_caption = section.settings.step2_caption
              when 3
                assign step_label = section.settings.step3_label
                assign step_caption = section.settings.step3_caption
              when 4
                assign step_label = section.settings.step4_label
                assign step_caption = section.settings.step4_caption
              when 5
                assign step_label = section.settings.step5_label
                assign step_caption = section.settings.step5_caption
              when 6
                assign step_label = section.settings.step6_label
                assign step_caption = section.settings.step6_caption
              when 7
                assign step_label = section.settings.step7_label
                assign step_caption = section.settings.step7_caption
              when 8
                assign step_label = section.settings.step8_label
                assign step_caption = section.settings.step8_caption
            endcase
            assign step_num = i | prepend: '0'
          -%}
          {%- if step_label != blank -%}
            <div class="craft-step">
              <div class="craft-step__rail" aria-hidden="true">
                <span class="craft-step__num">{{ step_num }}</span>
                <span class="craft-step__line"></span>
              </div>
              <div class="craft-step__body">
                <h3 class="craft-heading craft-step__label">{{ step_label }}</h3>
                {%- if step_caption != blank -%}
                  <p class="craft-body craft-step__caption">{{ step_caption }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} 04 · THE PAINTERS (team & provenance) {%- endcomment -%}
  <div class="craft-team">
    <div class="craft-wrap">
      <p class="craft-heading craft-team__lead">{{ section.settings.team_lead }}</p>
      {%- if section.settings.team_body != blank -%}
        <p class="craft-body craft-team__body">{{ section.settings.team_body }}</p>
      {%- endif -%}
      <div class="craft-origins">
        {%- for i in (1..2) -%}
          {%- liquid
            case i
              when 1
                assign origin_name = section.settings.origin1_name
                assign origin_text = section.settings.origin1_text
              when 2
                assign origin_name = section.settings.origin2_name
                assign origin_text = section.settings.origin2_text
            endcase
          -%}
          {%- if origin_name != blank -%}
            <div class="craft-origin">
              <div class="craft-origin__rule" aria-hidden="true">
                <span class="craft-origin__lozenge">&#9670;</span>
              </div>
              <h3 class="craft-heading craft-origin__name">{{ origin_name }}</h3>
              {%- if origin_text != blank -%}
                <p class="craft-body craft-origin__text">{{ origin_text }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      {%- if section.settings.team_mastery != blank -%}
        <p class="craft-body craft-mastery">{{ section.settings.team_mastery }}</p>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} 05 · MATERIALS & PERMANENCE {%- endcomment -%}
  <div class="craft-materials">
    <div class="craft-wrap">
      <h2 class="craft-heading craft-materials__heading">{{ section.settings.materials_heading }}</h2>
      <div class="craft-body craft-materials__body">
        {{ section.settings.materials_body }}
      </div>
    </div>
  </div>

  {%- comment -%} 05b · THE ARRIVAL (packaging & frames) {%- endcomment -%}
  <div class="craft-arrival">
    <div class="craft-wrap">
      <h2 class="craft-heading craft-arrival__heading">{{ section.settings.arrival_heading }}</h2>
      {%- if section.settings.arrival_intro != blank -%}
        <p class="craft-body craft-arrival__intro">{{ section.settings.arrival_intro }}</p>
      {%- endif -%}

      <div class="craft-items">
        {%- for i in (1..3) -%}
          {%- liquid
            case i
              when 1
                assign item_image = section.settings.item1_image
                assign item_title = section.settings.item1_title
                assign item_text = section.settings.item1_text
              when 2
                assign item_image = section.settings.item2_image
                assign item_title = section.settings.item2_title
                assign item_text = section.settings.item2_text
              when 3
                assign item_image = section.settings.item3_image
                assign item_title = section.settings.item3_title
                assign item_text = section.settings.item3_text
            endcase
          -%}
          {%- if item_title != blank -%}
            <div class="craft-item">
              <div class="craft-item__media">
                {%- if item_image != blank -%}
                  {{
                    item_image
                    | image_url: width: 720
                    | image_tag:
                      width: item_image.width,
                      height: item_image.height,
                      sizes: '(min-width: 700px) 30vw, 100vw',
                      widths: '200, 360, 540, 720',
                      loading: 'lazy',
                      alt: item_title
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              <h3 class="craft-heading craft-item__title">{{ item_title }}</h3>
              {%- if item_text != blank -%}
                <p class="craft-body craft-item__text">{{ item_text }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>
  </div>

  {%- comment -%} 06 · CLOSING CTA {%- endcomment -%}
  <div class="craft-cta">
    <div class="craft-wrap">
      <h2 class="craft-heading craft-cta__headline">{{ section.settings.cta_headline }}</h2>
      <a href="{{ section.settings.cta_url | default: '#' }}" class="button">
        {{ section.settings.cta_button_label }}
      </a>
      {%- if section.settings.cta_subline != blank -%}
        <p class="craft-body craft-cta__subline">{{ section.settings.cta_subline }}</p>
      {%- endif -%}
    </div>
  </div>

</div>

{% schema %}
{
  "name": "Our Craft",
  "tag": "section",
  "class": "craft-section-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image",
      "info": "Close-up of oil brushwork texture. Recommended: 2000 × 1000 px or larger."
    },
    {
      "type": "text",
      "id": "hero_headline",
      "label": "Headline",
      "default": "Real paint. Real hands. Made to outlive us all."
    },
    {
      "type": "text",
      "id": "hero_subline",
      "label": "Subline",
      "default": "Hand-painted pet portraits in oil on canvas"
    },
    {
      "type": "header",
      "content": "The real-paint anchor"
    },
    {
      "type": "text",
      "id": "anchor_heading",
      "label": "Heading",
      "default": "Why oil paint matters"
    },
    {
      "type": "text",
      "id": "anchor_intro",
      "label": "Intro line",
      "default": "The things that make an oil portrait feel alive can never come from a printer or a screen."
    },
    {
      "type": "image_picker",
      "id": "anchor_card1_icon",
      "label": "Card 1 icon"
    },
    {
      "type": "text",
      "id": "anchor_card1_title",
      "label": "Card 1 title",
      "default": "Layered glazing"
    },
    {
      "type": "text",
      "id": "anchor_card1_text",
      "label": "Card 1 text",
      "default": "Depth that printing can't fake"
    },
    {
      "type": "image_picker",
      "id": "anchor_card2_icon",
      "label": "Card 2 icon"
    },
    {
      "type": "text",
      "id": "anchor_card2_title",
      "label": "Card 2 title",
      "default": "Obsessed with the eyes"
    },
    {
      "type": "text",
      "id": "anchor_card2_text",
      "label": "Card 2 text",
      "default": "We revise until the likeness is right"
    },
    {
      "type": "image_picker",
      "id": "anchor_card3_icon",
      "label": "Card 3 icon"
    },
    {
      "type": "text",
      "id": "anchor_card3_title",
      "label": "Card 3 title",
      "default": "Brushwork you can feel"
    },
    {
      "type": "text",
