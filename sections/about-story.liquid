{%- style -%}
  #shopify-section-{{ section.id }} .about-module {
    padding: 6rem 0;
    color: rgb(var(--color-foreground));
    background-color: rgb(var(--color-background));
  }

  {%- if section.settings.background_tint -%}
    #shopify-section-{{ section.id }} .about-module {
      background-color: rgba(var(--color-foreground), 0.03);
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .about-heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: calc(var(--font-heading-scale) * 0.06rem);
    line-height: calc(1 + 0.3 / max(1, var(--font-heading-scale)));
  }

  #shopify-section-{{ section.id }} .about-body {
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  .about-wrap {
    max-width: 120rem;
    margin: 0 auto;
    padding-left: 1.6rem;
    padding-right: 1.6rem;
  }

  @media screen and (min-width: 750px) {
    .about-wrap {
      padding-left: 4rem;
      padding-right: 4rem;
    }
  }

  .about-story {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.2rem;
    align-items: center;
  }

  @media screen and (min-width: 750px) {
    .about-story {
      grid-template-columns: 1fr 1fr;
      gap: 6rem;
    }

    .about-story--media-right .about-story__media {
      order: 2;
    }
  }

  .about-story__media {
    position: relative;
  }

  .about-story__media img {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--maelin-border, rgba(0, 0, 0, 0.1));
  }

  .about-story__media .placeholder-svg {
    width: 100%;
    height: auto;
    background-color: rgba(var(--color-foreground), 0.04);
    fill: rgba(var(--color-foreground), 0.3);
  }

  .about-story__eyebrow {
    font-family: var(--serif-elegant, 'Cormorant Garamond', serif);
    font-style: italic;
    font-size: 1.6rem;
    letter-spacing: 0.04em;
    color: var(--maelin-gold-dark);
    margin: 0 0 1.2rem;
  }

  .about-story__heading {
    font-size: calc(var(--font-heading-scale) * 2.6rem);
    margin: 0 0 2rem;
  }

  @media screen and (min-width: 750px) {
    .about-story__heading {
      font-size: calc(var(--font-heading-scale) * 3.2rem);
    }
  }

  .about-story__text {
    font-size: 1.6rem;
    line-height: 1.8;
    color: rgba(var(--color-foreground), 0.78);
  }

  .about-story__text > * {
    margin: 0 0 1.6rem;
  }

  .about-story__text > *:last-child {
    margin-bottom: 0;
  }

  .about-story__signature {
    font-family: var(--serif-elegant, 'Cormorant Garamond', serif);
    font-style: italic;
    font-size: 1.8rem;
    color: var(--maelin-gold-dark);
    margin: 2.8rem 0 0;
  }
{%- endstyle -%}

<div class="about-module">
  <div class="about-wrap">
    <div class="about-story{% if section.settings.media_position == 'right' %} about-story--media-right{% endif %}">
      <div class="about-story__media">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              widths: '375, 550, 750, 1100, 1200',
              sizes: '(min-width: 750px) 50vw, 100vw',
              alt: section.settings.image.alt | default: 'Neo, founder of Maelin Studio'
          }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
      <div class="about-story__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="about-story__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="about-heading about-story__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.story != blank -%}
          <div class="about-body about-story__text">{{ section.settings.story }}</div>
        {%- endif -%}
        {%- if section.settings.signature != blank -%}
          <p class="about-story__signature">{{ section.settings.signature }}</p>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "About · Story",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "background_tint",
      "label": "Tinted background",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Photo",
      "info": "A photo of Neo with his cat works best. Portrait or square crops sit well beside the text."
    },
    {
      "type": "select",
      "id": "media_position",
      "label": "Photo position (desktop)",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "How it started"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "A photo, a cat, and a chance meeting in Boston"
    },
    {
      "type": "richtext",
      "id": "story",
      "label": "Story",
      "default": "<p>I'm Neo — a guy in Arizona who loves two things: oil painting and my cat.</p><p>In 2024, at Boston's Museum of Fine Arts, I got talking with Alex and Lukas, two classically trained painters visiting from Germany. Later I sent Alex a photo of my cat. He painted her — and the result stopped everyone I showed it to.</p><p>That was the whole idea. Alex and Lukas brought in two friends they trust at the easel, Leon and Mia, and Maelin Studio began.</p>"
    },
    {
      "type": "text",
      "id": "signature",
      "label": "Signature",
      "default": "— Neo, Founder · Arizona"
    }
  ],
  "presets": [
    {
      "name": "About · Story"
    }
  ]
}
{% endschema %}
