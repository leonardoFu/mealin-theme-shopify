{%- style -%}
  #shopify-section-{{ section.id }} .about-module {
    padding: 6.5rem 0;
    text-align: center;
    color: rgb(var(--color-foreground));
    background-color: rgb(var(--color-background));
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .about-module {
      padding: 8.5rem 0;
    }
  }

  {%- if section.settings.background_tint -%}
    #shopify-section-{{ section.id }} .about-module {
      background-color: rgba(var(--color-foreground), 0.03);
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .about-heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: calc(var(--font-heading-scale) * 0.06rem);
    line-height: calc(1 + 0.3 / max(1, var(--font-heading-scale)));
  }

  #shopify-section-{{ section.id }} .about-body {
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  .about-wrap {
    max-width: 120rem;
    margin: 0 auto;
    padding-left: 1.6rem;
    padding-right: 1.6rem;
  }

  @media screen and (min-width: 750px) {
    .about-wrap {
      padding-left: 4rem;
      padding-right: 4rem;
    }
  }

  .about-name__eyebrow {
    font-family: var(--serif-elegant, 'Cormorant Garamond', serif);
    font-style: italic;
    font-size: 1.6rem;
    letter-spacing: 0.04em;
    color: var(--maelin-gold-dark);
    margin: 0 0 1.2rem;
  }

  .about-name__heading {
    font-size: calc(var(--font-heading-scale) * 2.2rem);
    margin: 0 0 4rem;
  }

  @media screen and (min-width: 750px) {
    .about-name__heading {
      font-size: calc(var(--font-heading-scale) * 2.8rem);
    }
  }

  .about-name__row {
    list-style: none;
    margin: 0 auto;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: flex-start;
    gap: 1.6rem 1rem;
  }

  @media screen and (min-width: 750px) {
    .about-name__row {
      gap: 2.4rem;
    }
  }

  .about-name__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 5rem;
  }

  @media screen and (min-width: 750px) {
    .about-name__item {
      width: 8.5rem;
    }
  }

  .about-name__letter {
    font-family: var(--serif-elegant, 'Cormorant Garamond', serif);
    font-size: clamp(4rem, 12vw, 7rem);
    line-height: 1;
    color: var(--maelin-gold);
    margin-bottom: 1.4rem;
  }

  .about-name__item--connector .about-name__letter {
    color: var(--maelin-gold);
    opacity: 0.45;
  }

  .about-name__name {
    font-size: 1.4rem;
    letter-spacing: 0.02em;
    color: rgba(var(--color-foreground), 0.6);
    white-space: nowrap;
  }

  .about-name__name em {
    font-style: normal;
    font-weight: 600;
    color: var(--maelin-gold-dark);
  }

  .about-name__caption {
    font-family: var(--serif-elegant, 'Cormorant Garamond', serif);
    font-style: italic;
    font-size: 1.3rem;
    color: rgba(var(--color-foreground), 0.45);
  }

  .about-name__result {
    font-family: var(--serif-elegant, 'Cormorant Garamond', serif);
    font-style: italic;
    font-size: 1.8rem;
    color: var(--maelin-gold-dark);
    margin: 4.4rem 0 0;
  }

  @media screen and (min-width: 750px) {
    .about-name__result {
      font-size: 2.1rem;
    }
  }

  /* Scroll reveal (only armed by JS; no-JS / reduced-motion users see it immediately) */
  .about-name.is-armed .about-name__item {
    opacity: 0;
    transform: translateY(1.6rem);
  }

  .about-name.is-armed.is-visible .about-name__item {
    opacity: 1;
    transform: none;
    transition: opacity 0.6s ease, transform 0.6s ease;
    transition-delay: calc(var(--reveal-index, 0) * 95ms);
  }

  .about-name.is-armed .about-name__result {
    opacity: 0;
    transform: translateY(1.6rem);
  }

  .about-name.is-armed.is-visible .about-name__result {
    opacity: 1;
    transform: none;
    transition: opacity 0.6s ease, transform 0.6s ease;
    transition-delay: calc({{ section.blocks.size }} * 95ms);
  }
{%- endstyle -%}

<div class="about-module">
  <div class="about-wrap about-name">
    {%- if section.settings.eyebrow != blank -%}
      <p class="about-name__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="about-heading about-name__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="about-name__row">
        {%- for block in section.blocks -%}
          {%- assign is_connector = false -%}
          {%- if block.settings.name_before == blank and block.settings.name_letter == blank and block.settings.name_after == blank -%}
            {%- assign is_connector = true -%}
          {%- endif -%}
          <li
            class="about-name__item{% if is_connector %} about-name__item--connector{% endif %}"
            style="--reveal-index: {{ forloop.index0 }};"
            {{ block.shopify_attributes }}
          >
            <span class="about-name__letter">{{ block.settings.letter }}</span>
            {%- if is_connector -%}
              {%- if block.settings.caption != blank -%}
                <span class="about-name__caption">{{ block.settings.caption }}</span>
              {%- endif -%}
            {%- else -%}
              <span class="about-name__name">
                {{- block.settings.name_before -}}
                <em>{{- block.settings.name_letter -}}</em>
                {{- block.settings.name_after -}}
              </span>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- if section.settings.result != blank -%}
      <p class="about-name__result">{{ section.settings.result }}</p>
    {%- endif -%}
  </div>
</div>

<script>
  (function () {
    var section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;
    var root = section.querySelector('.about-name');
    if (!root || !('IntersectionObserver' in window)) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    root.classList.add('is-armed');
    var observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            root.classList.add('is-visible');
            observer.disconnect();
          }
        });
      },
      { threshold: 0.3 }
    );
    observer.observe(root);
  })();
</script>

{% schema %}
{
  "name": "About · Name",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "checkbox",
      "id": "background_tint",
      "label": "Tinted background",
      "default": true
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Where the name comes from"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Five of us. One name."
    },
    {
      "type": "text",
      "id": "result",
      "label": "Result line",
      "default": "Together — Maelin Studio."
    }
  ],
  "blocks": [
    {
      "type": "letter",
      "name": "Letter",
      "settings": [
        {
          "type": "text",
          "id": "letter",
          "label": "Large letter",
          "default": "M"
        },
        {
          "type": "paragraph",
          "content": "Leave all three name fields empty to make this a small connecting letter (e.g. the \"i\")."
        },
        {
          "type": "text",
          "id": "name_before",
          "label": "Name — before the letter",
          "info": "e.g. \"L\" for Leon"
        },
        {
          "type": "text",
          "id": "name_letter",
          "label": "Name — the borrowed letter",
          "info": "Highlighted in gold. e.g. \"e\" for Leon"
        },
        {
          "type": "text",
          "id": "name_after",
          "label": "Name — after the letter",
          "info": "e.g. \"on\" for Leon"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption (connecting letter only)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About · Name",
      "blocks": [
        { "type": "letter", "settings": { "letter": "M", "name_letter": "M", "name_after": "ia" } },
        { "type": "letter", "settings": { "letter": "a", "name_letter": "A", "name_after": "lex" } },
        { "type": "letter", "settings": { "letter": "e", "name_before": "L", "name_letter": "e", "name_after": "on" } },
        { "type": "letter", "settings": { "letter": "l", "name_letter": "L", "name_after": "ukas" } },
        { "type": "letter", "settings": { "letter": "i", "name_before": "M", "name_letter": "i", "name_after": "a" } },
        { "type": "letter", "settings": { "letter": "n", "name_letter": "N", "name_after": "eo" } }
      ]
    }
  ]
}
{% endschema %}
