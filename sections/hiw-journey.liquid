{%- style -%}
  #shopify-section-{{ section.id }} .hiw-module {
    padding: 6rem 0;
    text-align: center;
    color: rgb(var(--color-foreground));
    background-color: rgb(var(--color-background));
  }

  {%- if section.settings.background_tint -%}
    #shopify-section-{{ section.id }} .hiw-module {
      background-color: rgba(var(--color-foreground), 0.03);
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .hiw-heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: calc(var(--font-heading-scale) * 0.06rem);
    line-height: calc(1 + 0.3 / max(1, var(--font-heading-scale)));
  }

  #shopify-section-{{ section.id }} .hiw-body {
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  .hiw-wrap {
    max-width: 120rem;
    margin: 0 auto;
    padding-left: 1.6rem;
    padding-right: 1.6rem;
  }

  @media screen and (min-width: 750px) {
    .hiw-wrap {
      padding-left: 4rem;
      padding-right: 4rem;
    }
  }

  .hiw-journey__heading {
    font-size: calc(var(--font-heading-scale) * 2.8rem);
    margin: 0 0 0.8rem;
  }

  @media screen and (min-width: 750px) {
    .hiw-journey__heading {
      font-size: calc(var(--font-heading-scale) * 3.6rem);
    }
  }

  .hiw-journey__intro {
    font-size: 1.6rem;
    margin: 0 auto 4.4rem;
    max-width: 60rem;
    color: rgba(var(--color-foreground), 0.7);
  }

  .hiw-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4.8rem;
    max-width: 100rem;
    margin: 0 auto;
    position: relative;
  }

  @media screen and (min-width: 750px) {
    .hiw-steps {
      grid-template-columns: repeat(4, 1fr);
      gap: 3.6rem;
    }

    .hiw-steps::before {
      content: '';
      position: absolute;
      top: 2.7rem;
      left: 12%;
      right: 12%;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--maelin-gold-accent), var(--maelin-gold-accent), transparent);
    }
  }

  .hiw-step {
    text-align: center;
    position: relative;
  }

  .hiw-step__icon {
    width: 5.4rem;
    height: 5.4rem;
    border: 1px solid var(--maelin-gold);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--maelin-gold);
    margin: 0 auto 2.4rem;
    position: relative;
    z-index: 1;
    background-color: rgb(var(--color-background));
    transition: all 0.4s;
  }

  {%- if section.settings.background_tint -%}
    #shopify-section-{{ section.id }} .hiw-step__icon {
      background-color: var(--maelin-cream-3, rgb(var(--color-background)));
    }
  {%- endif -%}

  .hiw-step__icon svg {
    width: 1.8rem;
    height: 1.8rem;
    fill: var(--maelin-gold);
    transition: fill 0.4s;
  }

  .hiw-step:hover .hiw-step__icon {
    background: var(--maelin-gold);
  }

  .hiw-step:hover .hiw-step__icon svg {
    fill: #fff;
  }

  .hiw-step__title {
    font-size: calc(var(--font-heading-scale) * 1.7rem);
    margin: 0 0 1rem;
  }

  .hiw-step__text {
    font-size: 1.4rem;
    margin: 0;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.65);
  }
{%- endstyle -%}

<div class="hiw-module">
  <div class="hiw-wrap">
    {%- if section.settings.heading != blank -%}
      <h2 class="hiw-heading hiw-journey__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.intro != blank -%}
      <p class="hiw-body hiw-journey__intro">{{ section.settings.intro }}</p>
    {%- endif -%}
    <div class="hiw-steps">
      {%- for block in section.blocks -%}
        <div class="hiw-step" {{ block.shopify_attributes }}>
          <div class="hiw-step__icon" aria-hidden="true">
            {%- case block.settings.icon -%}
              {%- when 'upload' -%}{% render 'icon-upload' %}
              {%- when 'palette' -%}{% render 'icon-palette' %}
              {%- when 'brush' -%}{% render 'icon-brush' %}
              {%- when 'gift' -%}{% render 'icon-gift' %}
            {%- endcase -%}
          </div>
          {%- if block.settings.title != blank -%}
            <h3 class="hiw-heading hiw-step__title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <p class="hiw-body hiw-step__text">{{ block.settings.text }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "HIW · Your journey",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "checkbox",
      "id": "background_tint",
      "label": "Tinted background",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your journey"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Intro line",
      "default": "Four simple steps stand between your favourite photo and a finished oil painting — and we guide you through every one, with up to three free revisions so the likeness is exactly right."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "upload", "label": "Upload / Photo" },
            { "value": "palette", "label": "Palette / Style" },
            { "value": "brush", "label": "Brush / Create" },
            { "value": "gift", "label": "Gift / Receive" }
          ],
          "default": "upload"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Upload your photo"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Send us your favourite photograph and we'll help you choose the best reference."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HIW · Your journey",
      "blocks": [
        { "type": "step", "settings": { "icon": "upload", "title": "Upload your photo", "text": "Send us your favourite photograph. We'll help you choose the shot that best captures their character — the eyes, the expression, the tilt of the head." } },
        { "type": "step", "settings": { "icon": "palette", "title": "Share your preferences", "text": "A short questionnaire walks you through size, style, framing and the small details that make them unmistakably them." } },
        { "type": "step", "settings": { "icon": "brush", "title": "Approve the draft", "text": "Your artist sends a progress photo for your sign-off. Want a small change? You get up to three free revisions until it feels right." } },
        { "type": "step", "settings": { "icon": "gift", "title": "Receive your portrait", "text": "We varnish, hand-frame and ship your finished piece — carefully packaged to arrive safely, ready to hang or to gift." } }
      ]
    }
  ]
}
{% endschema %}
