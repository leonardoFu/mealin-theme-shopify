{%- style -%}
  #shopify-section-{{ section.id }} .about-module {
    padding: 7rem 0 5rem;
    text-align: center;
    color: rgb(var(--color-foreground));
    background-color: rgb(var(--color-background));
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .about-module {
      padding: 9rem 0 6rem;
    }
  }

  {%- if section.settings.background_tint -%}
    #shopify-section-{{ section.id }} .about-module {
      background-color: rgba(var(--color-foreground), 0.03);
    }
  {%- endif -%}

  #shopify-section-{{ section.id }} .about-heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    letter-spacing: calc(var(--font-heading-scale) * 0.06rem);
    line-height: calc(1 + 0.3 / max(1, var(--font-heading-scale)));
  }

  #shopify-section-{{ section.id }} .about-body {
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-weight: var(--font-body-weight);
    line-height: calc(1 + 0.8 / var(--font-body-scale));
  }

  .about-wrap {
    max-width: 120rem;
    margin: 0 auto;
    padding-left: 1.6rem;
    padding-right: 1.6rem;
  }

  @media screen and (min-width: 750px) {
    .about-wrap {
      padding-left: 4rem;
      padding-right: 4rem;
    }
  }

  .about-intro__eyebrow {
    font-family: var(--serif-elegant, 'Cormorant Garamond', serif);
    font-style: italic;
    font-size: 1.6rem;
    letter-spacing: 0.04em;
    color: var(--maelin-gold-dark);
    margin: 0 0 1.6rem;
  }

  .about-intro__headline {
    font-size: calc(var(--font-heading-scale) * 3rem);
    max-width: 60rem;
    margin: 0 auto;
  }

  @media screen and (min-width: 750px) {
    .about-intro__headline {
      font-size: calc(var(--font-heading-scale) * 4.2rem);
    }
  }

  .about-intro__subline {
    font-size: 1.6rem;
    max-width: 56rem;
    margin: 2rem auto 0;
    line-height: 1.7;
    color: rgba(var(--color-foreground), 0.7);
  }

  @media screen and (min-width: 750px) {
    .about-intro__subline {
      font-size: 1.8rem;
    }
  }
{%- endstyle -%}

<div class="about-module">
  <div class="about-wrap">
    {%- if section.settings.eyebrow != blank -%}
      <p class="about-intro__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.headline != blank -%}
      <h1 class="about-heading about-intro__headline">{{ section.settings.headline }}</h1>
    {%- endif -%}
    {%- if section.settings.subline != blank -%}
      <p class="about-body about-intro__subline">{{ section.settings.subline }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "About · Intro",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "background_tint",
      "label": "Tinted background",
      "default": false
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "About Maelin Studio"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "A few people who love oil paint — and your cat."
    },
    {
      "type": "textarea",
      "id": "subline",
      "label": "Subline",
      "default": "Your companion, painted by hand in real oil — the way the masters did it."
    }
  ],
  "presets": [
    {
      "name": "About · Intro"
    }
  ]
}
{% endschema %}
